---
import { Icon } from "@astrojs/starlight/components";

const { starlightRoute } = Astro.locals;
const PAGE_TITLE_ID = "_top";
const title = starlightRoute.entry.data.title;
const base = import.meta.env.BASE_URL || "/";
const path = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const site = Astro.site ?? new URL("https://ggx-docs.corridorplatforms.com");
const markdownPath = path === "/" ? "/index.md" : `${path}index.md`;
const markdownUrl = new URL(markdownPath, site).href;
const resourceBase = base.endsWith("/") ? base : `${base}/`;
const prompt = `Use this Corridor GGX documentation page as context and help answer questions about it: ${markdownUrl}`;
const chatGptUrl = `https://chatgpt.com/?q=${encodeURIComponent(prompt)}`;
const claudeUrl = `https://claude.ai/new?q=${encodeURIComponent(prompt)}`;
const perplexityUrl = `https://www.perplexity.ai/search/new?q=${encodeURIComponent(prompt)}`;
---

<div class="ggx-page-title-row">
  <h1 id={PAGE_TITLE_ID}>{title}</h1>
  <details class="ggx-ai-menu">
    <summary aria-label="Open AI options">
      <Icon name="comment" />
      <span>Ask AI</span>
      <Icon name="down-caret" />
    </summary>
    <div class="ggx-ai-menu__panel">
      <a href={chatGptUrl} target="_blank" rel="noreferrer">
        <Icon name="external" />
        <span>Open in ChatGPT</span>
      </a>
      <a href={claudeUrl} target="_blank" rel="noreferrer">
        <Icon name="external" />
        <span>Open in Claude</span>
      </a>
      <a href={perplexityUrl} target="_blank" rel="noreferrer">
        <Icon name="external" />
        <span>Open in Perplexity</span>
      </a>
      <a href={markdownUrl}>
        <Icon name="document" />
        <span>View Markdown</span>
      </a>
    </div>
  </details>
</div>

<style>
  @layer starlight.core {
    h1 {
      margin-top: 1rem;
      font-size: var(--sl-text-h1);
      line-height: var(--sl-line-height-headings);
      font-weight: 600;
      color: var(--sl-color-white);
    }
  }
</style>
