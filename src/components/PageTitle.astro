---
import { Icon } from "@astrojs/starlight/components";

const { starlightRoute } = Astro.locals;
const PAGE_TITLE_ID = "_top";
const title = starlightRoute.entry.data.title;
const path = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const markdownPath = path === "/" ? "/index.md" : `${path}index.md`;
---

<div class="ggx-page-title-row">
  <h1 id={PAGE_TITLE_ID}>{title}</h1>
  <details class="ggx-ai-menu">
    <summary aria-label="Open AI options">
      <Icon name="comment" />
      <span>Ask AI</span>
      <Icon name="down-caret" />
    </summary>
    <div class="ggx-ai-menu__panel">
      <a href="#" data-ggx-ai-link="chatgpt" target="_blank" rel="noreferrer">
        <Icon name="external" />
        <span>Open in ChatGPT</span>
      </a>
      <a href="#" data-ggx-ai-link="claude" target="_blank" rel="noreferrer">
        <Icon name="external" />
        <span>Open in Claude</span>
      </a>
      <a href="#" data-ggx-ai-link="gemini" target="_blank" rel="noreferrer">
        <Icon name="external" />
        <span>Open in Gemini</span>
      </a>
      <a href="#" data-ggx-ai-link="perplexity" target="_blank" rel="noreferrer">
        <Icon name="external" />
        <span>Open in Perplexity</span>
      </a>
      <a href={markdownPath} data-ggx-markdown-link>
        <Icon name="document" />
        <span>View Markdown</span>
      </a>
    </div>
  </details>
</div>

<script>
  const pagePath = window.location.pathname.endsWith("/")
    ? window.location.pathname
    : `${window.location.pathname}/`;
  const markdownPath = pagePath === "/" ? "/index.md" : `${pagePath}index.md`;
  const markdownUrl = new URL(markdownPath, window.location.origin).href;
  const prompt = `Use this GenGuardX (GGX) documentation page as context and help answer questions about it: ${markdownUrl}`;
  const encodedPrompt = encodeURIComponent(prompt);
  const aiTargets = {
    chatgpt: `https://chatgpt.com/?q=${encodedPrompt}`,
    claude: `https://claude.ai/new?q=${encodedPrompt}`,
    gemini: `https://gemini.google.com/app?q=${encodedPrompt}`,
    perplexity: `https://www.perplexity.ai/search/new?q=${encodedPrompt}`,
  };

  document.querySelectorAll("[data-ggx-ai-link]").forEach((link) => {
    if (!(link instanceof HTMLAnchorElement)) return;

    const target = link.dataset.ggxAiLink;
    if (!target || !(target in aiTargets)) return;

    link.href = aiTargets[target];
  });

  document.querySelectorAll("[data-ggx-markdown-link]").forEach((link) => {
    if (link instanceof HTMLAnchorElement) {
      link.href = markdownUrl;
    }
  });
</script>

<style>
  @layer starlight.core {
    h1 {
      margin-top: 1rem;
      font-size: var(--sl-text-h1);
      line-height: var(--sl-line-height-headings);
      font-weight: 600;
      color: var(--sl-color-white);
    }
  }
</style>
